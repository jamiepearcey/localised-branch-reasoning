# Copy this file to config.env and fill it in. config.env is git-ignored.
# It holds your vast.ai connection details and run knobs.

# ---- SSH connection (from the vast.ai instance "Connect" panel) ----
# vast.ai shows something like:  ssh -p 41234 root@123.45.67.89
SSH_HOST=123.45.67.89
SSH_PORT=41234
SSH_USER=root
# Path to the private key you registered with vast.ai.
SSH_KEY=$HOME/.ssh/id_ed25519

# ---- Remote layout ----
REMOTE_DIR=~/branch-disagreement

# ---- Optional Hugging Face token (for gated models / higher rate limits) ----
HF_TOKEN=

# ---- Experiment knobs (passed to scripts/run_experiment.py on the box) ----
MODEL=Qwen/Qwen2.5-14B-Instruct
NLI_MODEL=microsoft/deberta-large-mnli
DATASET=popqa            # sample | popqa | triviaqa
LIMIT=500
N_BRANCHES=8
TEMPERATURE=0.8
MAX_NEW_TOKENS=64
BRANCH_MODE=self_consistency   # self_consistency | localised
OUTPUT_PREFIX=popqa_run
